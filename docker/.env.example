# Copy to docker/.env.local and adjust before first boot.
# docker/.env.local is gitignored.

POSTGRES_DB=moodle
POSTGRES_USER=moodle
POSTGRES_PASSWORD=localdev_moodle_db

MOODLE_PORT=8080
MOODLE_WWWROOT=http://localhost:8080

MOODLE_ADMIN_USER=admin
MOODLE_ADMIN_PASSWORD=password1234
MOODLE_ADMIN_EMAIL=admin@localhost

# Optional — match Cloudflare Worker dev secret for AI Tutor streaming tests.
# AITUTOR_WORKER_SHARED_SECRET=
