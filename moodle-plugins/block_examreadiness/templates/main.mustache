<div class="block-examreadiness">
    {{#empty}}
        <p class="text-muted">{{#str}}noattempts, block_examreadiness{{/str}}</p>
    {{/empty}}
    {{^empty}}
        <div class="block-examreadiness-score">
            <div class="display-6 mb-2">{{readiness}}%</div>
            <div class="small text-muted mb-3">{{#str}}readiness_label, block_examreadiness{{/str}}</div>
            {{#cohortadjusted}}
                <div class="d-flex flex-wrap gap-2 mb-3">
                    {{#passprobability}}
                        <span class="badge bg-teal">{{#str}}pass_probability_label, block_examreadiness, {{passprobability}}{{/str}}</span>
                    {{/passprobability}}
                    <span class="badge bg-navy">{{#str}}prediction_model_label, block_examreadiness{{/str}}</span>
                </div>
            {{/cohortadjusted}}
        </div>
        <figure class="block-examreadiness-chart mb-0">
            <canvas class="block-examreadiness-radar" data-radar="{{radar}}" data-certificationid="{{certificationid}}" height="200"
                    aria-label="{{#str}}radar_aria, block_examreadiness{{/str}}"></canvas>
            <table class="sr-only">
                <caption>{{#str}}radar_summary, block_examreadiness{{/str}}</caption>
                <thead>
                    <tr>
                        <th scope="col">{{#str}}domain, block_examreadiness{{/str}}</th>
                        <th scope="col">{{#str}}score, block_examreadiness{{/str}}</th>
                    </tr>
                </thead>
                <tbody>
                    {{#radardomains}}
                        <tr>
                            <th scope="row">{{label}}</th>
                            <td>{{score}}%</td>
                        </tr>
                    {{/radardomains}}
                </tbody>
            </table>
        </figure>
        {{#misconceptions}}
            <h4 class="h6 mt-3">{{#str}}misconceptions_heading, block_examreadiness{{/str}}</h4>
            <ul class="list-unstyled block-examreadiness-misconceptions">
                {{#.}}
                    <li>{{objective}} — attempt {{attemptid}}</li>
                {{/.}}
            </ul>
        {{/misconceptions}}
    {{/empty}}
</div>
