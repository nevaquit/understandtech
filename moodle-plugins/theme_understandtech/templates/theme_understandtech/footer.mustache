{{!
    @template theme_understandtech/footer

    UnderstandTech global footer.
    Rendered by core_renderer::render_footer() in all layout files.

    Context variables:
    - wwwroot: string - Moodle $CFG->wwwroot
    - sitename: string - Site name
    - currentyear: string - Current year for copyright
    - footnote: string - Optional admin-configured footnote
    - moodledocslink: string - Moodle docs link HTML (required by Moodle)
    - logininfo: string - Login info HTML (required by Moodle)
    - homelink: string - Home link HTML (required by Moodle)
}}
<footer class="ut-footer" role="contentinfo" aria-label="Site footer">
    <div class="ut-container">

        <div class="ut-footer-grid">

            {{! Brand column }}
            <div class="ut-footer-brand">
                <a href="{{wwwroot}}" class="ut-footer-logo">Understand<span>Tech</span></a>
                <p>
                    AI-powered learning that adapts to you. Master in-demand skills,
                    earn verifiable credentials, and track your growth — all in one platform.
                </p>
                <div class="d-flex gap-3 mt-3">
                    <a href="https://twitter.com/understandtech" aria-label="UnderstandTech on Twitter" style="color:rgba(255,255,255,0.45);transition:color 0.15s ease;" onmouseover="this.style.color='#C9A227'" onmouseout="this.style.color='rgba(255,255,255,0.45)'">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.259 5.63zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                    </a>
                    <a href="https://linkedin.com/company/understandtech" aria-label="UnderstandTech on LinkedIn" style="color:rgba(255,255,255,0.45);transition:color 0.15s ease;" onmouseover="this.style.color='#C9A227'" onmouseout="this.style.color='rgba(255,255,255,0.45)'">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
                    </a>
                    <a href="https://github.com/nevaquit/understandtech" aria-label="UnderstandTech on GitHub" style="color:rgba(255,255,255,0.45);transition:color 0.15s ease;" onmouseover="this.style.color='#C9A227'" onmouseout="this.style.color='rgba(255,255,255,0.45)'">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
                    </a>
                </div>
            </div>

            {{! Platform column }}
            <div>
                <h3 class="ut-footer-col-title">Platform</h3>
                <ul class="ut-footer-links">
                    <li><a href="{{wwwroot}}/course/index.php">All Courses</a></li>
                    <li><a href="{{wwwroot}}/local/certmaster/index.php">Certifications</a></li>
                    <li><a href="{{wwwroot}}/local/aitutor/index.php">AI Tutor</a></li>
                    <li><a href="{{wwwroot}}/local/gamification/leaderboard.php">Leaderboard</a></li>
                    <li><a href="{{wwwroot}}/local/aigrading/index.php">AI Grading</a></li>
                </ul>
            </div>

            {{! Company column }}
            <div>
                <h3 class="ut-footer-col-title">Company</h3>
                <ul class="ut-footer-links">
                    <li><a href="{{wwwroot}}/about">About Us</a></li>
                    <li><a href="{{wwwroot}}/blog">Blog</a></li>
                    <li><a href="{{wwwroot}}/careers">Careers</a></li>
                    <li><a href="{{wwwroot}}/press">Press</a></li>
                    <li><a href="{{wwwroot}}/contact">Contact</a></li>
                </ul>
            </div>

            {{! Support column }}
            <div>
                <h3 class="ut-footer-col-title">Support</h3>
                <ul class="ut-footer-links">
                    <li><a href="{{wwwroot}}/help">Help Center</a></li>
                    <li><a href="{{wwwroot}}/status">System Status</a></li>
                    <li><a href="{{wwwroot}}/accessibility">Accessibility</a></li>
                    <li><a href="{{wwwroot}}/security">Security</a></li>
                </ul>
            </div>

        </div>

        {{! Bottom bar }}
        <div class="ut-footer-bottom">
            <span>© {{currentyear}} UnderstandTech. All rights reserved.</span>
            <div class="ut-footer-legal">
                <a href="{{wwwroot}}/privacy">Privacy Policy</a>
                <a href="{{wwwroot}}/terms">Terms of Service</a>
                <a href="{{wwwroot}}/cookies">Cookie Policy</a>
            </div>
        </div>

        {{! Moodle required elements (hidden visually but present for compliance) }}
        <div class="sr-only" aria-hidden="true">
            {{{footnote}}}
            {{{moodledocslink}}}
            {{{logininfo}}}
            {{{homelink}}}
        </div>

    </div>
</footer>
