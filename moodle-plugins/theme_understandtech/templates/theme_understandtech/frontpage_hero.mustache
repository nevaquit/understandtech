{{!
    @template theme_understandtech/frontpage_hero

    UnderstandTech frontpage hero section.
    Rendered by core_renderer::render_frontpage_hero() on the site front page.

    Context variables:
    - sitename: string - The Moodle site name
    - siteurl: string - The site root URL
    - isloggedin: bool - Whether the user is logged in
    - loginurl: string - Login page URL
    - dashboardurl: string - User dashboard URL
    - wwwroot: string - Moodle $CFG->wwwroot
}}
<section class="ut-hero" aria-labelledby="ut-hero-heading">
    <div class="ut-container">
        <div class="ut-hero-inner">

            {{! Left: Copy }}
            <div class="ut-hero-content">
                <span class="ut-eyebrow">AI-Powered Learning Platform</span>
                <h1 id="ut-hero-heading">
                    Master Any Subject.<br>
                    <span class="ut-accent">Earn Credentials</span><br>
                    That Matter.
                </h1>
                <p>
                    UnderstandTech combines an adaptive AI tutor, mastery-based certification,
                    and gamified learning to help professionals and students achieve deep,
                    verifiable expertise — faster than any traditional course.
                </p>

                <div class="ut-hero-cta-group">
                    {{#isloggedin}}
                    <a href="{{dashboardurl}}" class="btn-ut-primary">
                        Go to Dashboard
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </a>
                    {{/isloggedin}}
                    {{^isloggedin}}
                    <a href="{{loginurl}}" class="btn-ut-primary">
                        Start Learning Free
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </a>
                    <a href="#ut-features" class="btn-ut-outline">See How It Works</a>
                    {{/isloggedin}}
                </div>

                <div class="ut-hero-trust">
                    <span class="ut-trust-item">No credit card required</span>
                    <span class="ut-trust-item">WCAG 2.1 AA accessible</span>
                    <span class="ut-trust-item">Blockchain-verified credentials</span>
                </div>
            </div>

            {{! Right: Live Dashboard Widget }}
            <div class="ut-hero-visual" aria-hidden="true">
                <div class="ut-dashboard-widget">
                    <div class="ut-widget-header">
                        <span>Your Learning Dashboard</span>
                        <span class="ut-live-badge">● Live</span>
                    </div>

                    <div class="ut-progress-row">
                        <div class="ut-progress-label">
                            <span>AWS Solutions Architect</span>
                            <span class="ut-progress-pct">78%</span>
                        </div>
                        <div class="ut-progress">
                            <div class="ut-progress-fill" style="width:78%;" role="progressbar" aria-valuenow="78" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                    </div>

                    <div class="ut-progress-row">
                        <div class="ut-progress-label">
                            <span>Python for Data Science</span>
                            <span class="ut-progress-pct">45%</span>
                        </div>
                        <div class="ut-progress">
                            <div class="ut-progress-fill" style="width:45%;" role="progressbar" aria-valuenow="45" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                    </div>

                    <div class="ut-progress-row">
                        <div class="ut-progress-label">
                            <span>Cybersecurity Fundamentals</span>
                            <span class="ut-progress-pct">92%</span>
                        </div>
                        <div class="ut-progress">
                            <div class="ut-progress-fill" style="width:92%;" role="progressbar" aria-valuenow="92" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                    </div>

                    <div class="ut-xp-bar-container mt-3">
                        <div class="ut-xp-bar-label">
                            <span>Level 12 — Cloud Architect</span>
                            <span>2,340 / 3,000 XP</span>
                        </div>
                        <div class="ut-xp-bar">
                            <div class="ut-xp-fill" style="width:78%;"></div>
                        </div>
                    </div>

                    <div class="ut-widget-footer">
                        <div class="ut-widget-stat">
                            <span class="ut-widget-stat-label">Streak</span>
                            <span class="ut-widget-stat-value">🔥 14d</span>
                        </div>
                        <div class="ut-widget-stat">
                            <span class="ut-widget-stat-label">Rank</span>
                            <span class="ut-widget-stat-value">#47</span>
                        </div>
                        <div class="ut-widget-stat">
                            <span class="ut-widget-stat-label">Badges</span>
                            <span class="ut-widget-stat-value">23</span>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

{{! Stats Row }}
<section class="ut-section-sm ut-section-dark" aria-label="Platform statistics">
    <div class="ut-container">
        <div class="ut-stats-row">
            <div class="ut-stat-block">
                <span class="ut-stat-value" data-counter="12000" aria-label="12,000 plus active learners">12K+</span>
                <span class="ut-stat-label">Active Learners</span>
            </div>
            <div class="ut-stat-block">
                <span class="ut-stat-value" data-counter="8500" aria-label="8,500 plus credentials issued">8.5K+</span>
                <span class="ut-stat-label">Credentials Issued</span>
            </div>
            <div class="ut-stat-block">
                <span class="ut-stat-value" data-counter="94" aria-label="94 percent pass rate">94%</span>
                <span class="ut-stat-label">Exam Pass Rate</span>
            </div>
            <div class="ut-stat-block">
                <span class="ut-stat-value" aria-label="4.9 out of 5 rating">4.9★</span>
                <span class="ut-stat-label">Learner Rating</span>
            </div>
        </div>
    </div>
</section>
