{{!
    @template core/loginform

    UnderstandTech branded login form — OCW light palette (matches marketing site).

    Context variables:
    - loginurl: string - The form action URL
    - logintoken: string - CSRF token
    - error: string - Optional error message
    - username: string - Pre-filled username
    - recaptcha: string - Optional reCAPTCHA HTML
    - canloginasguest: bool - Show guest login link
    - guestloginurl: string - Guest login URL
    - forgotpasswordurl: string - Forgot password URL
    - canloginbyemail: bool - Allow email login
    - hasidentityproviders: bool - Whether SSO providers are available
    - identityproviders: array - SSO providers
    - logourl: string|null - Custom or site logo URL
    - hascustomlogo: bool - Whether a theme custom logo is configured
    - togglepassword: bool - Enable core password visibility toggle
    - smallscreensonly: bool - Limit password toggle to small screens
}}
<div class="ut-login-panel">

    {{#logourl}}
    <div class="ut-login-logo">
        <img src="{{logourl}}" class="img-fluid" alt="{{sitename}}" width="200" height="50">
    </div>
    {{/logourl}}
    {{^logourl}}
    <div class="ut-login-logo" aria-hidden="true">
        <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="48" height="48" rx="10" fill="#C9A227"/>
            <path d="M14 16h20M14 24h14M14 32h8" stroke="#0B1F3A" stroke-width="3" stroke-linecap="round"/>
            <circle cx="36" cy="32" r="6" fill="#0B1F3A"/>
            <path d="M33 32l2 2 4-4" stroke="#C9A227" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
    </div>
    {{/logourl}}

    <h1 class="ut-login-heading">{{#str}}login, core{{/str}}</h1>
    <p class="ut-login-subheading">{{#str}}loginwelcomemessage, theme_understandtech{{/str}}</p>

    {{#error}}
    <div class="alert alert-danger" role="alert" id="loginerrormessage" aria-live="assertive">
        <strong>{{#str}}error, core{{/str}}:</strong> {{error}}
    </div>
    {{/error}}

    {{#hasidentityproviders}}
    <div class="ut-sso-providers mb-3" aria-label="{{#str}}potentialidps, auth{{/str}}">
        {{#identityproviders}}
        <a href="{{url}}" class="btn btn-outline-secondary w-100 mb-2 d-flex align-items-center justify-content-center gap-2">
            {{#iconurl}}<img src="{{iconurl}}" alt="" width="20" height="20" aria-hidden="true">{{/iconurl}}
            {{name}}
        </a>
        {{/identityproviders}}
        <div class="text-center text-muted my-3" style="font-size:0.8125rem;letter-spacing:0.06em;">
            <span>{{#str}}or, core{{/str}}</span>
        </div>
    </div>
    {{/hasidentityproviders}}

    <form class="ut-login-form-fields login-form" action="{{loginurl}}" method="post" id="login" autocomplete="on">
        <input type="hidden" name="logintoken" value="{{logintoken}}">
        <input id="anchor" type="hidden" name="anchor" value="">

        <div class="form-group mb-3 login-form-username">
            <label for="username" class="form-label">
                {{#canloginbyemail}}{{#str}}usernameemail, core{{/str}}{{/canloginbyemail}}
                {{^canloginbyemail}}{{#str}}username, core{{/str}}{{/canloginbyemail}}
            </label>
            <input type="text"
                   name="username"
                   id="username"
                   class="form-control form-control-lg"
                   value="{{username}}"
                   autocomplete="username"
                   spellcheck="false"
                   autocapitalize="none"
                   required
                   aria-required="true">
        </div>

        <div class="form-group mb-4 login-form-password">
            <label for="password" class="form-label">{{#str}}password, core{{/str}}</label>
            <input type="password"
                   name="password"
                   id="password"
                   class="form-control form-control-lg"
                   autocomplete="current-password"
                   required
                   aria-required="true">
        </div>

        {{#recaptcha}}
        <div class="mb-3 login-form-recaptcha">{{{recaptcha}}}</div>
        {{/recaptcha}}

        <button type="submit" class="btn btn-primary btn-lg w-100 login-form-submit" id="loginbtn">
            {{#str}}login, core{{/str}}
        </button>
    </form>

    <div class="ut-login-links mt-3 login-form-forgotpassword">
        {{#forgotpasswordurl}}
        <a href="{{forgotpasswordurl}}">{{#str}}forgotaccount, core{{/str}}</a>
        {{/forgotpasswordurl}}
        {{#canloginasguest}}
        <span class="mx-2" aria-hidden="true">·</span>
        <a href="{{guestloginurl}}">{{#str}}loginguest, core{{/str}}</a>
        {{/canloginasguest}}
    </div>

</div>

{{#js}}
    require(['core/pending'], function(Pending) {
        document.getElementById('anchor').value = location.hash;
        const errorMessageDiv = document.getElementById('loginerrormessage');
        const errorMessage = errorMessageDiv?.textContent.trim();
        if (errorMessage) {
            const pendingJS = new Pending('login-move-focus');
            const usernameField = document.getElementById('username');
            setTimeout(function() {
                if (usernameField) {
                    usernameField.focus();
                }
                errorMessageDiv.innerHTML += "&nbsp;";
                pendingJS.resolve();
            }, 500);
        }
    });
    {{#togglepassword}}
        require(['core/togglesensitive'], function(ToggleSensitive) {
            ToggleSensitive.init("password", {{smallscreensonly}});
        });
    {{/togglepassword}}
    require(['core_form/submit'], function(Submit) {
        Submit.init("loginbtn");
    });
{{/js}}
