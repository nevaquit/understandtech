{{!
    @template core/loginform

    UnderstandTech world-class branded login form.
    Replaces the default Boost login form with the navy/gold/teal design system.

    Context variables:
    - loginurl: string - The form action URL
    - logintoken: string - CSRF token
    - error: string - Optional error message
    - username: string - Pre-filled username
    - recaptcha: string - Optional reCAPTCHA HTML
    - canloginasguest: bool - Show guest login link
    - guestloginurl: string - Guest login URL
    - forgotpasswordurl: string - Forgot password URL
    - canloginbyemail: bool - Allow email login
    - identityproviders: array - SSO providers
}}
<a class="ut-skip-link" href="#maincontent">{{#str}}skiptomain, theme_understandtech{{/str}}</a>

<div class="login-container" role="main" id="maincontent">

    <div class="ut-login-logo" aria-hidden="true">
        <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="48" height="48" rx="10" fill="#C9A227"/>
            <path d="M14 16h20M14 24h14M14 32h8" stroke="#0B1F3A" stroke-width="3" stroke-linecap="round"/>
            <circle cx="36" cy="32" r="6" fill="#0B1F3A"/>
            <path d="M33 32l2 2 4-4" stroke="#C9A227" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
    </div>

    <h1 class="ut-login-heading">{{#str}}login, core{{/str}}</h1>
    <p class="ut-login-subheading">{{#str}}loginwelcomemessage, theme_understandtech{{/str}}</p>

    {{#error}}
    <div class="alert alert-danger" role="alert" aria-live="assertive">
        <strong>{{#str}}error, core{{/str}}:</strong> {{error}}
    </div>
    {{/error}}

    {{#identityproviders}}
    <div class="ut-sso-providers mb-3" aria-label="{{#str}}potentialidps, auth{{/str}}">
        {{#identityproviders}}
        <a href="{{url}}" class="btn btn-outline-secondary w-100 mb-2 d-flex align-items-center justify-content-center gap-2">
            {{#iconurl}}<img src="{{iconurl}}" alt="" width="20" height="20" aria-hidden="true">{{/iconurl}}
            {{name}}
        </a>
        {{/identityproviders}}
        <div class="text-center text-muted my-3" style="font-size:0.8125rem;letter-spacing:0.06em;">
            <span>{{#str}}or, core{{/str}}</span>
        </div>
    </div>
    {{/identityproviders}}

    <form class="ut-login-form-fields" action="{{loginurl}}" method="post" id="login" autocomplete="on">
        <input type="hidden" name="logintoken" value="{{logintoken}}">
        <input type="hidden" name="anchor" value="">

        <div class="form-group mb-3">
            <label for="username" class="form-label">
                {{#canloginbyemail}}{{#str}}usernameemail, core{{/str}}{{/canloginbyemail}}
                {{^canloginbyemail}}{{#str}}username, core{{/str}}{{/canloginbyemail}}
            </label>
            <input type="text"
                   name="username"
                   id="username"
                   class="form-control form-control-lg"
                   value="{{username}}"
                   autocomplete="username"
                   spellcheck="false"
                   autocapitalize="none"
                   required
                   aria-required="true">
        </div>

        <div class="form-group mb-4" style="position:relative;">
            <label for="password" class="form-label">{{#str}}password, core{{/str}}</label>
            <input type="password"
                   name="password"
                   id="password"
                   class="form-control form-control-lg"
                   autocomplete="current-password"
                   style="padding-right:3rem;"
                   required
                   aria-required="true">
            <button type="button"
                    id="ut-pwd-toggle"
                    aria-label="{{#str}}showpassword, core{{/str}}"
                    style="position:absolute;right:0.75rem;bottom:0.625rem;background:none;border:none;color:rgba(255,255,255,0.45);cursor:pointer;padding:0.25rem;line-height:1;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                    <circle cx="12" cy="12" r="3"/>
                </svg>
            </button>
        </div>

        {{#recaptcha}}
        <div class="mb-3">{{{recaptcha}}}</div>
        {{/recaptcha}}

        <button type="submit" class="btn btn-primary btn-lg w-100" id="loginbtn">
            {{#str}}login, core{{/str}}
        </button>
    </form>

    <div class="ut-login-links mt-3">
        {{#forgotpasswordurl}}
        <a href="{{forgotpasswordurl}}">{{#str}}forgotaccount, core{{/str}}</a>
        {{/forgotpasswordurl}}
        {{#canloginasguest}}
        <span class="mx-2" aria-hidden="true">·</span>
        <a href="{{guestloginurl}}">{{#str}}loginguest, core{{/str}}</a>
        {{/canloginasguest}}
    </div>

</div>

<script>
(function() {
    var btn = document.getElementById('ut-pwd-toggle');
    var inp = document.getElementById('password');
    if (!btn || !inp) return;
    btn.addEventListener('click', function() {
        var isText = inp.type === 'text';
        inp.type = isText ? 'password' : 'text';
        btn.setAttribute('aria-label', isText ? 'Show password' : 'Hide password');
        btn.style.color = isText ? 'rgba(255,255,255,0.45)' : '#C9A227';
    });
}());
</script>
