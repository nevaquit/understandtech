<div class="ut-classroom-carousel d-flex flex-wrap gap-3">
    {{#hastracks}}
    {{#tracks}}
    <div class="card ut-track-card" style="min-width:220px;">
        <div class="card-body">
            <h3 class="h6 card-title">{{title}}</h3>
            <p class="text-muted small mb-2">{{examcode}}</p>
            <a href="{{url}}" class="btn btn-sm btn-primary">Open track</a>
        </div>
    </div>
    {{/tracks}}
    {{/hastracks}}
    {{^hastracks}}
    <p class="text-muted">{{#str}}certtracks, local_community{{/str}}</p>
    {{/hastracks}}
</div>
