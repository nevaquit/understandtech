<div id="local-aitutor-sidebar" class="local-aitutor-sidebar" aria-label="{{title}}">
    <div class="local-aitutor-header">
        <span>{{title}}</span>
        <button type="button" class="btn btn-sm btn-light local-aitutor-toggle" aria-label="Toggle tutor panel">☰</button>
    </div>
    <div class="local-aitutor-body">
        <textarea class="form-control local-aitutor-input mb-2" rows="3" placeholder="Ask the tutor…"></textarea>
        <button type="button" class="btn btn-primary btn-sm local-aitutor-send">Send</button>
        <div class="local-aitutor-output mt-2" role="log" aria-live="polite"></div>
    </div>
</div>
{{#js}}
require(['local_aitutor/tutor_sidebar'], function(Tutor) {
    Tutor.init({{courseid}}, {{cmid}});
});
{{/js}}
