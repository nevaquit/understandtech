# GitHub Actions self-hosted runner sudo allowlist
# Deploy to /etc/sudoers.d/gha-runner (mode 0440)
# Derived from Phase 5 deployment workflow in docs/playbook.md

Defaults:gha-runner !requiretty

# Monorepo sync in /opt/understandtech-plugins (deploy workflow)
gha-runner ALL=(gha-runner) NOPASSWD: /usr/bin/git fetch origin main
gha-runner ALL=(gha-runner) NOPASSWD: /usr/bin/git reset --hard origin/main

# Moodle CLI maintenance and upgrades
gha-runner ALL=(root) NOPASSWD: /usr/bin/php /var/www/moodle/admin/cli/maintenance.php --enable
gha-runner ALL=(root) NOPASSWD: /usr/bin/php /var/www/moodle/admin/cli/maintenance.php --disable
gha-runner ALL=(root) NOPASSWD: /usr/bin/php /var/www/moodle/admin/cli/purge_caches.php
gha-runner ALL=(root) NOPASSWD: /usr/bin/php /var/www/moodle/admin/cli/upgrade.php --non-interactive --allow-unstable
gha-runner ALL=(root) NOPASSWD: /usr/bin/bash /opt/understandtech-plugins/scripts/moodle-upgrade-direct-pg.sh
gha-runner ALL=(root) NOPASSWD: /usr/bin/bash /opt/understandtech-plugins/scripts/apply-nginx-config.sh
gha-runner ALL=(root) NOPASSWD: /usr/bin/bash /opt/understandtech-plugins/scripts/recover-origin-db.sh
gha-runner ALL=(root) NOPASSWD: /usr/bin/bash /opt/understandtech-plugins/scripts/moodle-sync-version-hash.sh

# Plugin sync into www-data-owned Moodle dirroot (deploy workflow)
gha-runner ALL=(root) NOPASSWD: /usr/bin/mkdir -p /var/www/moodle/local/*
gha-runner ALL=(root) NOPASSWD: /usr/bin/mkdir -p /var/www/moodle/mod/*
gha-runner ALL=(root) NOPASSWD: /usr/bin/mkdir -p /var/www/moodle/theme/*
gha-runner ALL=(root) NOPASSWD: /usr/bin/mkdir -p /var/www/moodle/blocks/*
gha-runner ALL=(root) NOPASSWD: /usr/bin/mkdir -p /var/www/moodle/question/behaviour/*
gha-runner ALL=(root) NOPASSWD: /usr/bin/rsync -av --delete --exclude=.git --exclude=.github --exclude=\*.md --exclude=tests/ /opt/understandtech-plugins/moodle-plugins/local_*/ /var/www/moodle/local/*/
gha-runner ALL=(root) NOPASSWD: /usr/bin/rsync -av --delete --exclude=.git --exclude=.github --exclude=\*.md --exclude=tests/ /opt/understandtech-plugins/moodle-plugins/mod_*/ /var/www/moodle/mod/*/
gha-runner ALL=(root) NOPASSWD: /usr/bin/rsync -av --delete --exclude=.git --exclude=.github --exclude=\*.md --exclude=tests/ /opt/understandtech-plugins/moodle-plugins/theme_*/ /var/www/moodle/theme/*/
gha-runner ALL=(root) NOPASSWD: /usr/bin/rsync -av --delete --exclude=.git --exclude=.github --exclude=\*.md --exclude=tests/ /opt/understandtech-plugins/moodle-plugins/block_*/ /var/www/moodle/blocks/*/
gha-runner ALL=(root) NOPASSWD: /usr/bin/rsync -av --delete --exclude=.git --exclude=.github --exclude=\*.md --exclude=tests/ /opt/understandtech-plugins/moodle-plugins/qbehaviour_*/ /var/www/moodle/question/behaviour/*/

# Remove README-only placeholder dirs before upgrade (scripts/remove-placeholder-plugins.sh)
gha-runner ALL=(root) NOPASSWD: /opt/understandtech-plugins/scripts/remove-placeholder-plugins.sh

# Plugin sync ownership after rsync
gha-runner ALL=(root) NOPASSWD: /usr/bin/chown -R www-data\:www-data /var/www/moodle/local/*
gha-runner ALL=(root) NOPASSWD: /usr/bin/chown -R www-data\:www-data /var/www/moodle/mod/*
gha-runner ALL=(root) NOPASSWD: /usr/bin/chown -R www-data\:www-data /var/www/moodle/theme/*
gha-runner ALL=(root) NOPASSWD: /usr/bin/chown -R www-data\:www-data /var/www/moodle/blocks/*
gha-runner ALL=(root) NOPASSWD: /usr/bin/chown -R www-data\:www-data /var/www/moodle/question/behaviour/*

# Redis cache flush (application DB 0 only)
gha-runner ALL=(root) NOPASSWD: /usr/bin/cat /etc/moodle/redis_password

# Post-deploy smoke test: read PgBouncer dbhost from config.php (640 root:www-data)
gha-runner ALL=(root) NOPASSWD: /usr/bin/grep dbhost /var/www/moodle/config.php

# Service reload/restart after config changes (PHP-FPM: restart ONLY — reload forbidden)
gha-runner ALL=(root) NOPASSWD: /usr/bin/systemctl reload nginx
gha-runner ALL=(root) NOPASSWD: /usr/bin/systemctl restart php8.3-fpm
gha-runner ALL=(root) NOPASSWD: /usr/bin/bash /opt/understandtech-plugins/scripts/restart-php-fpm-vm.sh
gha-runner ALL=(root) NOPASSWD: /usr/bin/bash /opt/understandtech-plugins/scripts/post-deploy-stabilize-vm.sh
gha-runner ALL=(root) NOPASSWD: /usr/bin/bash /opt/understandtech-plugins/scripts/sync-theme-understandtech-vm.sh
gha-runner ALL=(root) NOPASSWD: /usr/bin/bash /opt/understandtech-plugins/scripts/theme-upgrade-purge-vm.sh
gha-runner ALL=(root) NOPASSWD: /usr/bin/bash /opt/understandtech-plugins/scripts/sync-sudoers-vm.sh
gha-runner ALL=(root) NOPASSWD: /usr/bin/bash /opt/understandtech-plugins/scripts/ensure-origin-healthy-vm.sh
gha-runner ALL=(root) NOPASSWD: /usr/bin/bash /opt/understandtech-plugins/scripts/seed-security-plus-course-vm.sh
gha-runner ALL=(root) NOPASSWD: /usr/bin/bash /opt/understandtech-plugins/scripts/seed-comptia-a-plus-course-vm.sh
gha-runner ALL=(root) NOPASSWD: /usr/bin/bash /opt/understandtech-plugins/scripts/seed-network-plus-course-vm.sh
gha-runner ALL=(root) NOPASSWD: /usr/bin/bash /opt/understandtech-plugins/scripts/fix-sec701-course-filters-vm.sh
gha-runner ALL=(root) NOPASSWD: /usr/bin/bash /opt/understandtech-plugins/scripts/fix-net009-course-filters-vm.sh
gha-runner ALL=(root) NOPASSWD: /usr/bin/bash /opt/understandtech-plugins/scripts/fix-aplus-course-filters-vm.sh
gha-runner ALL=(root) NOPASSWD: /usr/bin/bash /opt/understandtech-plugins/scripts/verify-net009-web-health.sh
gha-runner ALL=(root) NOPASSWD: /usr/bin/bash /opt/understandtech-plugins/scripts/verify-cert-course-pages.sh
gha-runner ALL=(root) NOPASSWD: /usr/bin/bash /opt/understandtech-plugins/scripts/verify-sec701-launch-scale.sh
gha-runner ALL=(root) NOPASSWD: /usr/bin/bash /opt/understandtech-plugins/scripts/verify-net009-launch-scale.sh
gha-runner ALL=(root) NOPASSWD: /usr/bin/bash /opt/understandtech-plugins/scripts/verify-aplus-launch-scale.sh
gha-runner ALL=(root) NOPASSWD: /usr/bin/bash /opt/understandtech-plugins/scripts/kill-stale-aplus-seed-vm.sh
gha-runner ALL=(root) NOPASSWD: /usr/bin/bash /opt/understandtech-plugins/scripts/verify-moodle-web-health.sh
gha-runner ALL=(root) NOPASSWD: /usr/bin/bash /opt/understandtech-plugins/scripts/fix-moodle-dir-permissions-vm.sh
gha-runner ALL=(root) NOPASSWD: /usr/bin/bash /opt/understandtech-plugins/scripts/fix-moodle-chdir-quick-vm.sh
gha-runner ALL=(root) NOPASSWD: /usr/bin/bash /opt/understandtech-plugins/scripts/rollback-deploy-vm.sh
gha-runner ALL=(root) NOPASSWD: /usr/bin/bash /opt/understandtech-plugins/scripts/apply-php-fpm-pool-vm.sh
gha-runner ALL=(root) NOPASSWD: /usr/bin/systemctl reload pgbouncer

# Pre-deploy SHA marker (deploy workflow)
gha-runner ALL=(root) NOPASSWD: /usr/bin/tee /tmp/understandtech-pre-deploy-sha

# verify-moodle-web-health.sh drops to www-data for Moodle CLI probes
gha-runner ALL=(www-data) NOPASSWD: /usr/bin/php /var/www/moodle/admin/cli/maintenance.php
gha-runner ALL=(www-data) NOPASSWD: /usr/bin/php /var/www/moodle/admin/cli/purge_caches.php
gha-runner ALL=(www-data) NOPASSWD: /usr/bin/php

# Runner service management (bootstrap only — restrict in production if desired)
gha-runner ALL=(root) NOPASSWD: /opt/actions-runner/svc.sh *
