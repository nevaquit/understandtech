# Copy to .env and fill in before running authenticated tests.
# Never commit .env with real credentials.

STAGING_URL=https://understandtech.app
# Moodle username (or email if auth_email enabled on the site).
STAGING_TEST_USER_EMAIL=
STAGING_TEST_USER_PASSWORD=

# Course or activity URL where local_aitutor sidebar renders (required for tutor tests).
# Production SEC701 Security+ course: /course/view.php?id=3
E2E_COURSE_PATH=/course/view.php?id=3

# Optional instructor account for future quiz/lab specs.
STAGING_INSTRUCTOR_EMAIL=
STAGING_INSTRUCTOR_PASSWORD=

# Stripe payment E2E (payment-flow.spec.ts) — skipped unless STRIPE_TEST=1
# STRIPE_TEST=1
# E2E_PAID_COURSE_PATH=/course/view.php?id=<paid-course-id>
